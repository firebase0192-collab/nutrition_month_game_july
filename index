    document.getElementById('scr-input').value = '';
    document.getElementById('scr-input').className = 'scramble-input';
    showScrView('question');
    startScrTimer(DIFF_SECONDS[scrDifficulty]);
    setTimeout(() => document.getElementById('scr-input').focus(), 50);
  });
