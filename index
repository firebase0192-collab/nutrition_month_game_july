  clearTOFTimer();
  let t = secs;
  const el = document.getElementById('tof-timer');
  el.textContent = t;
  el.className = 'timer-count';
  tofTimer = setInterval(() => {
    t--;
    el.textContent = t;
    if (t <= 3) el.className = 'timer-count urgent';
    if (t <= 0) {
      clearInterval(tofTimer);
      answerTOF(null);
    }
  }, 1000);
}

function answerTOF(userAnswer) {
  clearTOFTimer();
  tofUsedBoxes.add(tofCurrentQ);
  tofTries++;
  const q = TOF_QUESTIONS[tofCurrentQ];
  const timeUp = userAnswer === null;
  const correct = !timeUp && userAnswer === q.a;
  if (correct) { tofScore++; launchConfetti(35); }
  updateTOFHeader();

  const isLast = tofTries >= 3;

  const nextBtn = {
    label: isLast ? '➡ See Final Score' : '↩ Back to Board',
    cls: '',
    action: () => {
      hideResult();
      if (isLast) { showTOFFinal(); return; }
      buildTOFBoard();
    }
  };

  showResult({
    icon: timeUp ? '⏰' : correct ? '🎉' : '😢',
    title: timeUp ? "Time's Up!" : correct ? 'Correct!' : 'Oops!',
    titleClass: correct ? 'correct' : 'wrong',
    sub: timeUp ? "You ran out of time!" : correct ? 'Nice one!' : "No worries—let's learn it!",
    question: q.q,
    showAnswer: true,
    answerText: `Correct answer: ${q.a ? 'TRUE' : 'FALSE'}`,
    detail: q.detail,
    showPoints: correct,
    buttons: [nextBtn]
  });
}

