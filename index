function startScrTimer(secs) {
  clearScrTimer();
  let t = secs;
  const el = document.getElementById('scr-timer');
  el.textContent = t;
  el.className = 'timer-count';
  scrTimer = setInterval(() => {
    t--;
    el.textContent = t;
    if (t <= Math.ceil(secs * 0.3)) el.className = 'timer-count urgent';
    if (t <= 0) {
      clearInterval(scrTimer);
      finishScrRound(false, true);
    }
  }, 1000);
}

function checkScramble() {
  clearScrTimer();
  const input = document.getElementById('scr-input').value.trim().toUpperCase();
  const bank = SCRAMBLE_FINAL[scrDifficulty];
  const wordObj = bank[scrCurrentBox % bank.length];
  const correct = input === wordObj.word;
  finishScrRound(correct, false);
}

function finishScrRound(correct, timeUp) {
  clearScrTimer();
  scrUsedBoxes[scrDifficulty].add(scrCurrentBox);
  scrTries++;
  updateScrHeader();

  const bank = SCRAMBLE_FINAL[scrDifficulty];
  const wordObj = bank[scrCurrentBox % bank.length];
  const ansCard = document.getElementById('scr-answer-card');
  const titleMap = { easy: 'EASY', normal: 'NORMAL', hard: 'DIFFICULT' };

  if (correct) {
    scrScore++;
    launchConfetti(40);
    document.getElementById('scr-answer-icon').textContent = '🎉';
    document.getElementById('scr-answer-title').textContent = `${titleMap[scrDifficulty]} — ROUND ${scrCurrentBox + 1} ANSWER`;
    document.getElementById('scr-answer-sub').textContent = 'Great job! The correct word is:';
    document.getElementById('scr-answer-word').textContent = wordObj.word;
    document.getElementById('scr-answer-word').style.color = 'var(--green)';
    document.getElementById('scr-answer-hint').innerHTML = `<strong>💡 Hint:</strong> ${wordObj.hint}`;
    document.getElementById('scr-input').className = 'scramble-input correct';
    ansCard.style.borderTop = '5px solid #22c55e';
  } else {
    document.getElementById('scr-answer-icon').textContent = timeUp ? '⏰' : '😢';
    document.getElementById('scr-answer-title').textContent = timeUp ? "TIME'S UP!" : 'WRONG ANSWER';
    document.getElementById('scr-answer-sub').textContent = 'No worries — here was the correct word:';
    document.getElementById('scr-answer-word').textContent = wordObj.word;
    document.getElementById('scr-answer-word').style.color = 'var(--red)';
    document.getElementById('scr-answer-hint').innerHTML = `<strong>💡 Hint:</strong> ${wordObj.hint}`;
    ansCard.style.borderTop = '5px solid #ef4444';
  }

  const isLastTry = scrTries >= 3;
  document.getElementById('scr-continue-btn').textContent = isLastTry ? '➡ See Final Score' : '↩ Choose Difficulty Again';
  document.getElementById('scr-continue-btn').onclick = isLastTry ? showScrFinal : afterScrRoundContinue;

  showScrView('answer');
}

