function readySetGo(callback) {
  const overlay = document.getElementById('rsg-overlay');
  const text = document.getElementById('rsg-text');
  overlay.style.display = 'flex';
  const seq = ['READY?', 'SET...', 'GO!'];
  let i = 0;
  text.textContent = seq[i];
  text.className = 'rsg-text';
  text.style.animation = 'none';
  requestAnimationFrame(() => { text.style.animation = 'rsg-pop 0.5s ease'; });

  const interval = setInterval(() => {
    i++;
    if (i < seq.length) {
      text.textContent = seq[i];
      text.className = i === seq.length - 1 ? 'rsg-text go' : 'rsg-text';
      text.style.animation = 'none';
      requestAnimationFrame(() => { text.style.animation = 'rsg-pop 0.5s ease'; });
    } else {
      clearInterval(interval);
      overlay.style.display = 'none';
      callback();
    }
  }, 600);
}

