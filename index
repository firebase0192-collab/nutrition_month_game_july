<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nutrition Month Game 🥦</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800;900&display=swap');

  :root {
    --green: #2d8b4e;
    --green-light: #4caf70;
    --green-dark: #1a5c32;
    --yellow: #f9c22e;
    --orange: #f97316;
    --red: #ef4444;
    --blue: #3b82f6;
    --purple: #8b5cf6;
    --teal: #14b8a6;
    --cream: #fef9ee;
    --white: #ffffff;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Nunito', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
    background: #1a5c32;
  }

  /* ===== ANIMATIONS ===== */
  @keyframes float { 0%,100%{transform:translateY(0px);} 50%{transform:translateY(-12px);} }
  @keyframes pulse-glow { 0%,100%{box-shadow:0 0 20px rgba(249,194,46,0.4);} 50%{box-shadow:0 0 40px rgba(249,194,46,0.9);} }
  @keyframes bounce-in { 0%{transform:scale(0) rotate(-10deg);opacity:0;} 60%{transform:scale(1.15) rotate(3deg);} 80%{transform:scale(0.95) rotate(-1deg);} 100%{transform:scale(1) rotate(0deg);opacity:1;} }
  @keyframes slide-up { from{transform:translateY(60px);opacity:0;} to{transform:translateY(0);opacity:1;} }
  @keyframes slide-down { from{transform:translateY(-40px);opacity:0;} to{transform:translateY(0);opacity:1;} }
  @keyframes wiggle { 0%,100%{transform:rotate(0deg);} 25%{transform:rotate(-5deg);} 75%{transform:rotate(5deg);} }
  @keyframes confetti-fall { 0%{transform:translateY(-20px) rotate(0deg);opacity:1;} 100%{transform:translateY(110vh) rotate(720deg);opacity:0;} }
  @keyframes timer-pulse { 0%,100%{transform:scale(1);color:#2d8b4e;} 50%{transform:scale(1.1);color:#ef4444;} }
  @keyframes star-pop { 0%{transform:scale(0) rotate(0deg);opacity:0;} 50%{transform:scale(1.3) rotate(180deg);opacity:1;} 100%{transform:scale(1) rotate(360deg);opacity:1;} }
  @keyframes shake { 0%,100%{transform:translateX(0);} 20%{transform:translateX(-8px);} 40%{transform:translateX(8px);} 60%{transform:translateX(-5px);} 80%{transform:translateX(5px);} }
  @keyframes flash-screen { 0%,100%{background-color:transparent;} 50%{background-color:rgba(249,194,46,0.5);} }
  @keyframes rsg-pop { 0%{transform:scale(0.3);opacity:0;} 50%{transform:scale(1.4);opacity:1;} 100%{transform:scale(1);opacity:1;} }
  @keyframes card-flip-in { from{transform:rotateY(90deg);opacity:0;} to{transform:rotateY(0deg);opacity:1;} }
  @keyframes countdown-tick { 0%{transform:scale(1.3);opacity:0.6;} 100%{transform:scale(1);opacity:1;} }

  .screen { display: none; min-height: 100vh; }
  .screen.active { display: flex; flex-direction: column; }

  /* ===== HOME SCREEN ===== */
  #home { background: linear-gradient(135deg, #1a5c32 0%, #2d8b4e 40%, #1a5c32 100%); position: relative; overflow: hidden; align-items: center; justify-content: center; padding: 20px; }
  .food-particle { position: absolute; font-size: 2rem; animation: float 3s ease-in-out infinite; opacity: 0.35; pointer-events: none; user-select: none; }
  .home-circle { position: absolute; border-radius: 50%; background: rgba(255,255,255,0.04); }
  .home-content { position: relative; z-index: 2; text-align: center; max-width: 700px; width: 100%; }
  .home-badge { display: inline-block; background: var(--yellow); color: var(--green-dark); font-weight: 900; font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase; padding: 6px 20px; border-radius: 50px; margin-bottom: 16px; animation: slide-down 0.6s ease; }
  .home-title { font-family: 'Fredoka One', cursive; font-size: clamp(2.5rem, 7vw, 5rem); color: var(--white); line-height: 1; text-shadow: 0 4px 20px rgba(0,0,0,0.4); animation: bounce-in 0.8s ease 0.2s both; margin-bottom: 4px; }
  .home-title span { color: var(--yellow); }
  .home-subtitle { font-size: clamp(1rem, 3vw, 1.4rem); color: rgba(255,255,255,0.85); font-weight: 700; margin-bottom: 8px; animation: slide-up 0.7s ease 0.4s both; }
  .home-tagline { font-size: 0.95rem; color: rgba(255,255,255,0.6); margin-bottom: 30px; animation: slide-up 0.7s ease 0.5s both; font-style: italic; }
  .player-welcome { color: white; font-size: 1.1rem; font-weight: 800; margin-bottom: 20px; background: rgba(255,255,255,0.12); display:inline-block; padding:8px 24px; border-radius:50px; }
  .player-welcome span { color: var(--yellow); }

  .game-cards { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; animation: slide-up 0.7s ease 0.6s both; }
  .game-card { background: var(--white); border-radius: 24px; padding: 28px 22px; width: 190px; cursor: pointer; transition: transform 0.25s, box-shadow 0.25s; box-shadow: 0 8px 30px rgba(0,0,0,0.25); border: 3px solid transparent; position: relative; overflow: hidden; }
  .game-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 5px; background: var(--card-accent, var(--green)); border-radius: 24px 24px 0 0; }
  .game-card:hover { transform: translateY(-10px) scale(1.03); box-shadow: 0 20px 50px rgba(0,0,0,0.35); border-color: var(--card-accent, var(--green)); }
  .game-card.disabled { opacity: 0.5; cursor: not-allowed; pointer-events: none; }
  .card-icon { font-size: 3rem; margin-bottom: 12px; display: block; animation: float 2.5s ease-in-out infinite; }
  .card-title { font-family: 'Fredoka One', cursive; font-size: 1.2rem; color: #1a1a1a; margin-bottom: 6px; }
  .card-desc { font-size: 0.78rem; color: #666; line-height: 1.4; }
  .card-play-btn { margin-top: 14px; display: inline-block; background: var(--card-accent, var(--green)); color: white; padding: 6px 18px; border-radius: 50px; font-size: 0.8rem; font-weight: 800; letter-spacing: 0.5px; }

  /* ===== NAME ENTRY SCREEN ===== */
  #name-entry { background: linear-gradient(135deg, #1a5c32 0%, #2d8b4e 60%, #1a5c32 100%); align-items: center; justify-content: center; padding: 20px; }
  .name-card { background: white; border-radius: 28px; padding: 44px 36px; max-width: 440px; width: 100%; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.35); animation: bounce-in 0.6s ease; }
  .name-card .emoji-row { font-size: 2.5rem; margin-bottom: 10px; }
  .name-card h1 { font-family: 'Fredoka One', cursive; color: var(--green-dark); font-size: 1.7rem; margin-bottom: 8px; }
  .name-card p { color: #777; font-size: 0.9rem; margin-bottom: 22px; font-weight: 600; }
  .name-input { width: 100%; padding: 16px 20px; border: 3px solid #e5e7eb; border-radius: 16px; font-size: 1.1rem; font-family: 'Nunito', sans-serif; font-weight: 700; text-align: center; outline: none; transition: border-color 0.2s; margin-bottom: 18px; }
  .name-input:focus { border-color: var(--green); }

  /* ===== COMMON GAME STYLES ===== */
  .game-header { background: var(--green-dark); padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; box-shadow: 0 4px 20px rgba(0,0,0,0.3); flex-wrap: wrap; gap: 10px; }
  .game-header-title { font-family: 'Fredoka One', cursive; color: var(--yellow); font-size: 1.4rem; }
  .game-header-sub { color: rgba(255,255,255,0.7); font-size: 0.8rem; }
  .btn-home { background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.3); color: white; padding: 8px 18px; border-radius: 50px; font-size: 0.85rem; font-weight: 700; cursor: pointer; transition: all 0.2s; font-family: 'Nunito', sans-serif; }
  .btn-home:hover { background: rgba(255,255,255,0.25); border-color: white; }
  .btn-reset { background: rgba(239,68,68,0.25); border: 2px solid rgba(239,68,68,0.5); color: white; padding: 8px 18px; border-radius: 50px; font-size: 0.85rem; font-weight: 700; cursor: pointer; transition: all 0.2s; font-family: 'Nunito', sans-serif; }
  .btn-reset:hover { background: rgba(239,68,68,0.45); border-color: #fff; }

  .game-body { flex: 1; background: linear-gradient(160deg, #f0fdf4 0%, #dcfce7 100%); padding: 30px 20px; display: flex; flex-direction: column; align-items: center; gap: 20px; }

  .timer-ring-wrap { display: flex; align-items: center; justify-content: center; gap: 10px; background: white; border-radius: 20px; padding: 10px 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
  .timer-label { font-size: 0.85rem; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: 1px; }
  .timer-count { font-family: 'Fredoka One', cursive; font-size: 2.5rem; color: var(--green); min-width: 60px; text-align: center; transition: color 0.3s; }
  .timer-count.urgent { color: var(--red); animation: timer-pulse 0.5s ease infinite; }

  .big-btn { background: var(--green); color: white; border: none; padding: 14px 40px; border-radius: 50px; font-size: 1.1rem; font-weight: 800; cursor: pointer; font-family: 'Nunito', sans-serif; transition: all 0.2s; box-shadow: 0 6px 20px rgba(45,139,78,0.4); letter-spacing: 0.5px; }
  .big-btn:hover { background: var(--green-light); transform: translateY(-3px); box-shadow: 0 10px 28px rgba(45,139,78,0.5); }
  .big-btn:active { transform: translateY(0); }
  .big-btn.yellow { background: var(--yellow); color: var(--green-dark); box-shadow: 0 6px 20px rgba(249,194,46,0.4); }
  .big-btn.yellow:hover { background: #fbbf24; box-shadow: 0 10px 28px rgba(249,194,46,0.6); }
  .big-btn.red { background: var(--red); box-shadow: 0 6px 20px rgba(239,68,68,0.4); }
  .big-btn.blue { background: var(--blue); box-shadow: 0 6px 20px rgba(59,130,246,0.4); }
  .big-btn.gray { background: #9ca3af; box-shadow: 0 6px 20px rgba(156,163,175,0.4); }
  .big-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none !important; }

  .confetti-piece { position: fixed; width: 10px; height: 10px; top: -20px; border-radius: 2px; pointer-events: none; z-index: 9999; animation: confetti-fall linear forwards; }

  /* ===== RESULT OVERLAY ===== */
  .result-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 500; padding: 20px; backdrop-filter: blur(4px); }
  .result-card { background: white; border-radius: 28px; padding: 36px 32px; max-width: 440px; width: 100%; text-align: center; animation: bounce-in 0.5s ease; box-shadow: 0 25px 80px rgba(0,0,0,0.4); }
  .result-icon { font-size: 4rem; display: block; margin-bottom: 10px; animation: star-pop 0.6s ease; }
  .result-title { font-family: 'Fredoka One', cursive; font-size: 2rem; margin-bottom: 6px; }
  .result-title.correct { color: var(--green); }
  .result-title.wrong { color: var(--red); }
  .result-sub { font-size: 1rem; color: #666; margin-bottom: 16px; font-weight: 700; }
  .result-question { background: #f8fafb; border-radius: 14px; padding: 16px; font-size: 0.95rem; color: #333; margin-bottom: 16px; line-height: 1.5; font-weight: 600; }
  .result-answer { background: linear-gradient(135deg, #ecfdf5, #d1fae5); border-radius: 14px; padding: 14px; margin-bottom: 20px; }
  .result-answer strong { display: block; font-size: 1.3rem; font-family: 'Fredoka One', cursive; color: var(--green); margin-bottom: 4px; }
  .result-answer .detail { font-size: 0.85rem; color: #555; line-height: 1.4; }
  .result-points { display: inline-block; background: var(--yellow); color: var(--green-dark); font-weight: 900; font-size: 1rem; padding: 8px 24px; border-radius: 50px; margin-bottom: 20px; animation: pulse-glow 1.5s ease infinite; }

  /* Confirm modal (Are you sure / Home) */
  .confirm-card { background: white; border-radius: 24px; padding: 32px 28px; max-width: 380px; width: 100%; text-align: center; animation: bounce-in 0.4s ease; box-shadow: 0 25px 80px rgba(0,0,0,0.4); }
  .confirm-card .c-icon { font-size: 3rem; margin-bottom: 8px; }
  .confirm-card h3 { font-family: 'Fredoka One', cursive; color: var(--green-dark); font-size: 1.3rem; margin-bottom: 18px; line-height: 1.4; }
  .confirm-card h3 span { color: var(--orange); }
  .confirm-btns { display: flex; gap: 12px; justify-content: center; }

  /* Ready Set Go overlay */
  .rsg-overlay { position: fixed; inset: 0; background: rgba(26,92,50,0.92); display:none; align-items:center; justify-content:center; z-index: 600; }
  .rsg-text { font-family: 'Fredoka One', cursive; font-size: 4rem; color: white; animation: rsg-pop 0.5s ease; text-shadow: 0 6px 20px rgba(0,0,0,0.4); }
  .rsg-text.go { color: var(--yellow); font-size: 5rem; }

  /* ============================ SCRAMBLE WORD GAME ============================ */
  #scramble { background: linear-gradient(160deg, #1a5c32, #2d8b4e); }
  .scramble-board-screen { background: linear-gradient(160deg, #1a5c32, #2d8b4e); }

  .instructions-card { background: white; border-radius: 28px; padding: 36px; max-width: 580px; width: 100%; box-shadow: 0 10px 40px rgba(0,0,0,0.1); animation: slide-up 0.5s ease; }
  .instructions-title { font-family: 'Fredoka One', cursive; font-size: 1.9rem; color: var(--green); margin-bottom: 18px; text-align: center; }
  .instruction-step { display: flex; gap: 16px; align-items: flex-start; margin-bottom: 14px; }
  .step-num { background: var(--green); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.9rem; flex-shrink: 0; }
  .step-text { font-size: 0.93rem; color: #444; font-weight: 600; line-height: 1.5; padding-top: 4px; }
  .timing-pill-row { display:flex; gap:8px; flex-wrap:wrap; margin-top: 6px; }
  .timing-pill { font-size: 0.78rem; font-weight: 800; padding: 4px 12px; border-radius: 50px; }
  .timing-pill.easy { background: #d1fae5; color: #047857; }
  .timing-pill.normal { background: #fef3c7; color: #92400e; }
  .timing-pill.hard { background: #fee2e2; color: #b91c1c; }

  .difficulty-row { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; max-width: 620px; width: 100%; animation: slide-up 0.5s ease; }
  .diff-card { background: white; border-radius: 22px; padding: 26px 22px; width: 170px; text-align: center; cursor: pointer; transition: all 0.25s; box-shadow: 0 8px 26px rgba(0,0,0,0.18); border: 3px solid transparent; }
  .diff-card:hover { transform: translateY(-8px) scale(1.04); box-shadow: 0 16px 40px rgba(0,0,0,0.28); }
  .diff-card.easy { border-color: #34d399; } .diff-card.easy:hover { background: #ecfdf5; }
  .diff-card.normal { border-color: #fbbf24; } .diff-card.normal:hover { background: #fffbeb; }
  .diff-card.hard { border-color: #f87171; } .diff-card.hard:hover { background: #fef2f2; }
  .diff-card .d-icon { font-size: 2.2rem; margin-bottom: 8px; }
  .diff-card .d-title { font-family: 'Fredoka One', cursive; font-size: 1.2rem; margin-bottom: 4px; }
  .diff-card .d-sub { font-size: 0.78rem; color: #888; font-weight: 700; }
  .diff-card .d-streak { margin-top:10px; font-size: 0.72rem; font-weight: 800; color: var(--green); }
  .diff-card.locked { opacity: 0.45; cursor: not-allowed; pointer-events: none; }

  .box-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; max-width: 560px; width: 100%; animation: slide-up 0.5s ease; }
  .box-btn { aspect-ratio: 1; border-radius: 20px; border: 3px solid rgba(255,255,255,0.3); background: rgba(255,255,255,0.12); color: white; font-family: 'Fredoka One', cursive; font-size: 1.8rem; cursor: pointer; transition: all 0.25s; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 20px rgba(0,0,0,0.2); position: relative; overflow: hidden; }
  .box-btn:hover:not(.used) { transform: scale(1.08) rotate(2deg); background: rgba(255,255,255,0.25); border-color: var(--yellow); box-shadow: 0 10px 30px rgba(0,0,0,0.3); animation: wiggle 0.4s ease; }
  .box-btn.used { opacity: 0.3; cursor: not-allowed; pointer-events: none; transform: scale(0.9); }
  .box-btn .box-num { font-size: 0.9rem; position: absolute; top: 6px; left: 10px; opacity: 0.7; }

  .scramble-board { background: white; border-radius: 28px; padding: 32px; max-width: 540px; width: 100%; text-align: center; box-shadow: 0 10px 50px rgba(0,0,0,0.15); animation: bounce-in 0.5s ease; }
  .round-label { display: inline-block; background: var(--green); color: white; font-weight: 800; font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase; padding: 5px 18px; border-radius: 50px; margin-bottom: 14px; }
  .scramble-instruction { font-size: 0.9rem; color: #888; margin-bottom: 10px; font-weight: 600; }
  .scramble-word { font-family: 'Fredoka One', cursive; font-size: clamp(2.2rem, 6vw, 4rem); color: var(--green-dark); letter-spacing: 6px; margin-bottom: 14px; line-height: 1; background: linear-gradient(135deg, var(--green-dark), var(--green)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .scramble-hint { background: #f0fdf4; border-radius: 12px; padding: 10px 16px; font-size: 0.9rem; color: #555; margin-bottom: 20px; border: 1px solid #bbf7d0; }
  .scramble-hint strong { color: var(--green); }
  .scramble-input-wrap { display: flex; gap: 10px; }
  .scramble-input { flex: 1; padding: 14px 20px; border: 3px solid #e5e7eb; border-radius: 16px; font-size: 1.1rem; font-family: 'Nunito', sans-serif; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; transition: border-color 0.2s; outline: none; }
  .scramble-input:focus { border-color: var(--green); }
  .scramble-input.correct { border-color: #22c55e; background: #f0fdf4; }
  .scramble-input.wrong { border-color: var(--red); animation: shake 0.4s ease; background: #fef2f2; }

  .answer-card { background: white; border-radius: 28px; padding: 36px 32px; max-width: 500px; width: 100%; text-align: center; box-shadow: 0 10px 50px rgba(0,0,0,0.15); animation: bounce-in 0.5s ease; }
  .answer-card .answer-word { font-family: 'Fredoka One', cursive; font-size: 3.2rem; color: var(--green); margin: 16px 0; letter-spacing: 4px; }
  .tries-indicator { display: flex; gap: 8px; justify-content: center; margin-top: 10px; }
  .try-dot { width: 14px; height: 14px; border-radius: 50%; background: #e5e7eb; transition: background 0.3s; }
  .try-dot.played { background: var(--green); }
  .try-dot.lost { background: var(--red); }

  .streak-bar { display:flex; gap:6px; justify-content:center; margin-top: 14px; }
  .streak-dot { width: 16px; height: 16px; border-radius: 50%; border: 2px solid #e5e7eb; transition: all 0.3s; }
  .streak-dot.hit { background: var(--green); border-color: var(--green); animation: star-pop 0.4s ease; }

  /* Final score screen flash */
  .final-score-card { background: white; border-radius: 28px; padding: 40px 32px; max-width: 460px; width: 100%; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.3); animation: bounce-in 0.6s ease; position: relative; }
  .final-flash { position: fixed; inset:0; pointer-events:none; z-index: 50; animation: flash-screen 0.6s ease 3; }
  .final-score-num { font-family: 'Fredoka One', cursive; font-size: 4rem; color: var(--yellow); -webkit-text-stroke: 2px var(--green-dark); margin: 10px 0; }
  .final-player-name { font-family: 'Fredoka One', cursive; font-size: 1.6rem; color: var(--green-dark); }

  /* ============================ TRUE OR FALSE GAME ============================ */
  #tof { background: #f0fdf4; }
  .tof-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; max-width: 560px; width: 100%; animation: slide-up 0.5s ease; }
  .tof-box { aspect-ratio: 1; border-radius: 16px; background: var(--green); color: white; font-family: 'Fredoka One', cursive; font-size: 1.5rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.25s; box-shadow: 0 4px 14px rgba(45,139,78,0.35); position: relative; overflow: hidden; }
  .tof-box:hover:not(.used) { transform: scale(1.1) rotate(-2deg); box-shadow: 0 10px 28px rgba(45,139,78,0.5); background: var(--green-light); }
  .tof-box.used { opacity: 0.3; cursor: not-allowed; pointer-events: none; transform: scale(0.9); }

  .tof-question-card { background: white; border-radius: 28px; padding: 36px 32px; max-width: 540px; width: 100%; text-align: center; box-shadow: 0 10px 50px rgba(0,0,0,0.12); animation: bounce-in 0.5s ease; }
  .tof-q-num { display: inline-block; background: var(--yellow); color: var(--green-dark); font-weight: 900; font-size: 0.85rem; padding: 4px 16px; border-radius: 50px; margin-bottom: 16px; letter-spacing: 1px; }
  .tof-q-text { font-size: 1.3rem; font-weight: 700; color: #1a1a1a; line-height: 1.4; margin-bottom: 24px; }
  .tof-btns { display: flex; gap: 16px; justify-content: center; }
  .tof-true-btn, .tof-false-btn { flex: 1; padding: 18px; border: none; border-radius: 20px; font-family: 'Fredoka One', cursive; font-size: 1.6rem; cursor: pointer; transition: all 0.2s; max-width: 160px; box-shadow: 0 6px 20px rgba(0,0,0,0.15); }
  .tof-true-btn { background: #22c55e; color: white; }
  .tof-true-btn:hover { background: #16a34a; transform: translateY(-4px) scale(1.05); }
  .tof-false-btn { background: var(--red); color: white; }
  .tof-false-btn:hover { background: #dc2626; transform: translateY(-4px) scale(1.05); }

  /* ============================ MATCHING / MEMORY GAME ============================ */
  #matching { background: linear-gradient(160deg, #fef9ee, #fef3c7); }
  .matching-instruction { background: white; border-radius: 28px; padding: 36px; max-width: 600px; width: 100%; box-shadow: 0 10px 40px rgba(0,0,0,0.1); animation: slide-up 0.5s ease; }
  .matching-title { font-family: 'Fredoka One', cursive; font-size: 1.8rem; color: var(--orange); margin-bottom: 14px; text-align: center; }
  .match-example { background: #fff7ed; border-radius: 14px; padding: 16px; margin-bottom: 16px; border: 1px solid #fed7aa; }
  .match-example-row { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; font-size: 0.95rem; font-weight: 700; color: #444; }
  .match-arrow { color: var(--orange); font-size: 1.2rem; }

  .preview-card { background: white; border-radius: 28px; padding: 36px; max-width: 560px; width: 100%; box-shadow: 0 10px 40px rgba(0,0,0,0.1); animation: slide-up 0.5s ease; text-align:center; }
  .preview-title { font-family: 'Fredoka One', cursive; font-size: 1.6rem; color: var(--orange); margin-bottom: 18px; }
  .preview-pair-row { display:flex; align-items:center; justify-content: space-between; background:#fff7ed; border-radius:14px; padding: 14px 18px; margin-bottom: 10px; font-weight: 700; font-size: 1rem; color:#444; animation: slide-up 0.4s ease; }
  .preview-pair-row .pp-arrow { color: var(--orange); font-size: 1.3rem; }

  .preview-slide-wrap { min-height: 140px; display:flex; align-items:center; justify-content:center; }
  .preview-slide {
    font-family: 'Fredoka One', cursive;
    font-size: 1.9rem;
    color: var(--orange);
    background: #fff7ed;
    border: 3px solid #fed7aa;
    border-radius: 20px;
    padding: 28px 24px;
    width: 100%;
    text-align: center;
    animation: bounce-in 0.5s ease;
    line-height: 1.4;
  }
  .preview-slide .pp-benefit { display:block; font-family:'Nunito',sans-serif; font-size: 1.05rem; color: #444; font-weight: 800; margin-top: 10px; }
  .preview-slide .pp-arrow { color: var(--orange); font-size: 1.3rem; }
  .preview-dots { display:flex; gap:6px; justify-content:center; margin-top: 16px; }
  .preview-dot { width: 10px; height: 10px; border-radius: 50%; background: #e5e7eb; transition: all 0.3s; }
  .preview-dot.active { background: var(--orange); width: 26px; border-radius: 6px; }
  .preview-dot.done { background: #fdba74; }

  .memory-meta { display:flex; gap: 14px; justify-content:center; flex-wrap:wrap; }
  .memory-pill { background: white; border-radius: 16px; padding: 10px 22px; box-shadow: 0 4px 16px rgba(0,0,0,0.1); text-align:center; }
  .memory-pill .mp-label { font-size: 0.72rem; color:#888; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
  .memory-pill .mp-value { font-family: 'Fredoka One', cursive; font-size: 1.6rem; color: var(--orange); }
  .memory-pill .mp-value.timer-low { color: var(--red); animation: timer-pulse 0.5s ease infinite; }

  .memory-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; max-width: 600px; width: 100%; animation: slide-up 0.5s ease; }
  .memory-card { aspect-ratio: 0.85; border-radius: 16px; cursor: pointer; position: relative; transform-style: preserve-3d; transition: transform 0.4s; }
  .memory-card.flipped { transform: rotateY(180deg); }
  .memory-card.matched { opacity: 0.55; pointer-events: none; }
  .mc-face { position: absolute; inset: 0; border-radius: 16px; display:flex; align-items:center; justify-content:center; text-align:center; padding: 8px; backface-visibility: hidden; box-shadow: 0 4px 14px rgba(0,0,0,0.15); }
  .mc-back { background: linear-gradient(135deg, var(--orange), #fb923c); color:white; font-size: 1.8rem; }
  .mc-front { background: white; color:#333; font-size: 0.78rem; font-weight: 800; transform: rotateY(180deg); border: 2px solid #fed7aa; line-height:1.3; }
  .memory-card.matched .mc-front { background: linear-gradient(135deg, #ecfdf5, #d1fae5); border-color: #22c55e; color: var(--green); }
  .memory-card.wrong-flash .mc-front { background: #fef2f2; border-color: var(--red); animation: shake 0.4s ease; }

  .matching-progress { text-align: center; font-size: 0.9rem; font-weight: 700; color: #666; }
  .match-score { font-size: 2rem; font-family: 'Fredoka One', cursive; color: var(--green); }

  .score-badge { background: var(--yellow); color: var(--green-dark); padding: 4px 14px; border-radius: 50px; font-weight: 900; font-size: 0.9rem; }

  @media (max-width: 480px) {
    .game-cards { flex-direction: column; align-items: center; }
    .game-card { width: 100%; max-width: 280px; }
    .box-grid { grid-template-columns: repeat(5, 1fr); gap: 8px; }
    .tof-grid { grid-template-columns: repeat(5, 1fr); gap: 8px; }
    .memory-grid { grid-template-columns: repeat(4, 1fr); gap: 8px; }
    .scramble-input-wrap { flex-direction: column; }
    .difficulty-row { flex-direction: column; align-items: center; }
    .diff-card { width: 100%; max-width: 260px; }
  }
</style>
</head>
<body>

<div id="particles"></div>

<!-- ============ NAME ENTRY SCREEN ============ -->
<div id="name-entry" class="screen active">
  <div class="name-card">
    <div class="emoji-row">🥦🍎🥕</div>
    <h1>Welcome, Champion!</h1>
    <p>Enter your name to start tracking your nutrition game scores</p>
    <input type="text" id="player-name-input" class="name-input" placeholder="Type your name..." maxlength="20" autocomplete="off">
    <button class="big-btn" style="width:100%;" onclick="submitPlayerName()">▶ LET'S PLAY</button>
  </div>
</div>

<!-- ============ HOME SCREEN ============ -->
<div id="home" class="screen">
  <div class="home-circle" style="width:600px;height:600px;top:-200px;left:-150px;"></div>
  <div class="home-circle" style="width:400px;height:400px;bottom:-100px;right:-100px;"></div>

  <div class="home-content">
    <div class="home-badge">🇵🇭 July 2026 — Nutrition Month</div>
    <div class="home-title">NUTRISYON<br><span>MONTH</span> 🥦</div>
    <div class="home-subtitle">Nutrisyon sa Kalikasan, Ating Pangalagaan!</div>
    <div class="player-welcome">👋 Player: <span id="home-player-name">Guest</span></div>
    <div class="home-tagline">Test your nutrition knowledge — learn while you play!</div>

    <div class="game-cards">
      <div class="game-card" style="--card-accent:#f97316;" onclick="startScramble()">
        <span class="card-icon">🔤</span>
        <div class="card-title">Word Scramble</div>
        <div class="card-desc">Unscramble nutrition words by difficulty level!</div>
        <div class="card-play-btn" style="background:#f97316;">PLAY →</div>
      </div>
      <div class="game-card" style="--card-accent:#3b82f6;" onclick="startTOF()">
        <span class="card-icon">✅</span>
        <div class="card-title">True or False</div>
        <div class="card-desc">Test what you know about healthy eating habits!</div>
        <div class="card-play-btn" style="background:#3b82f6;">PLAY →</div>
      </div>
      <div class="game-card" style="--card-accent:#8b5cf6;" onclick="startMatching()">
        <span class="card-icon">🧠</span>
        <div class="card-title">Memory Match</div>
        <div class="card-desc">Flip cards and match foods to their benefits!</div>
        <div class="card-play-btn" style="background:#8b5cf6;">PLAY →</div>
      </div>
    </div>

    <div style="margin-top:30px;">
      <button class="btn-reset" onclick="confirmReset()">🔄 RESET GAME</button>
    </div>
  </div>
</div>

<!-- ============ SCRAMBLE SCREEN ============ -->
<div id="scramble" class="screen">
  <div class="game-header">
    <div>
      <div class="game-header-title">🔤 Word Scramble</div>
      <div class="game-header-sub" id="scr-header-sub">Pick a difficulty — unscramble the nutrition word!</div>
    </div>
    <div style="display:flex;align-items:center;gap:10px;">
      <span class="score-badge">⭐ <span id="scr-score-disp">0</span> pts</span>
      <span class="score-badge">Try <span id="scr-tries">0</span>/3</span>
      <button class="btn-reset" onclick="confirmReset()">RESET</button>
      <button class="btn-home" onclick="confirmGoHome()">🏠 Home</button>
    </div>
  </div>

  <!-- Instructions -->
  <div id="scr-instructions" class="game-body">
    <div class="instructions-card">
      <div class="instructions-title">📋 How to Play</div>
      <div class="instruction-step">
        <div class="step-num">1</div>
        <div class="step-text">Open the game board and choose a difficulty level: <strong>Easy, Normal, or Difficult</strong>.</div>
      </div>
      <div class="instruction-step">
        <div class="step-num">2</div>
        <div class="step-text">You can choose <strong>Easy, Normal, or Difficult</strong> anytime — no need to unlock anything. You only have <strong>3 tries total</strong>, so choose wisely!</div>
      </div>
      <div class="instruction-step">
        <div class="step-num">3</div>
        <div class="step-text">Unscramble the word correctly before time runs out.
          <div class="timing-pill-row">
            <span class="timing-pill easy">Easy — 5 secs</span>
            <span class="timing-pill normal">Normal — 7 secs</span>
            <span class="timing-pill hard">Difficult — 10 secs</span>
          </div>
        </div>
      </div>
      <div class="instruction-step">
        <div class="step-num">4</div>
        <div class="step-text">Players are required to state the correct word aloud.</div>
      </div>
      <div class="instruction-step">
        <div class="step-num">5</div>
        <div class="step-text">The game master will reveal the answer to verify whether the guess is correct.</div>
      </div>
      <div class="instruction-step">
        <div class="step-num">6</div>
        <div class="step-text">The player will be <strong>eliminated</strong> if their guessed answer is incorrect.</div>
      </div>
      <div style="text-align:center;margin-top:20px;">
        <button class="big-btn" style="background:#f97316;box-shadow:0 6px 20px rgba(249,115,22,0.4);" onclick="showScrDifficulty()">▶ CHOOSE DIFFICULTY</button>
      </div>
    </div>
  </div>

  <!-- Difficulty selection -->
  <div id="scr-difficulty" class="game-body scramble-board-screen" style="display:none;">
    <div style="text-align:center;color:white;animation:slide-down 0.5s ease;">
      <div style="font-family:'Fredoka One',cursive;font-size:1.8rem;margin-bottom:6px;">Choose Difficulty</div>
      <div style="font-size:0.9rem;opacity:0.8;">Pick any level, anytime — you have 3 tries total!</div>
    </div>
    <div class="difficulty-row">
      <div class="diff-card easy" onclick="enterDifficulty('easy')">
        <div class="d-icon">🟢</div>
        <div class="d-title">Easy</div>
        <div class="d-sub">5-letter words • 5 secs</div>
      </div>
      <div class="diff-card normal" onclick="enterDifficulty('normal')">
        <div class="d-icon">🟡</div>
        <div class="d-title">Normal</div>
        <div class="d-sub">6-letter words • 7 secs</div>
      </div>
      <div class="diff-card hard" onclick="enterDifficulty('hard')">
        <div class="d-icon">🔴</div>
        <div class="d-title">Difficult</div>
        <div class="d-sub">7+ letter words • 10 secs</div>
      </div>
    </div>
    <div class="memory-pill" style="margin-top:6px;">
      <div class="mp-label">Overall Points</div>
      <div class="mp-value" id="scr-diff-score-disp">0</div>
    </div>
    <div class="tries-indicator" id="scr-dots-top"></div>
  </div>

  <!-- Board view (boxes for chosen difficulty) -->
  <div id="scr-board" class="game-body scramble-board-screen" style="display:none;">
    <div style="text-align:center;color:white;animation:slide-down 0.5s ease;">
      <div style="font-family:'Fredoka One',cursive;font-size:1.8rem;margin-bottom:6px;" id="scr-board-title">EASY — Choose Your Box!</div>
      <div style="font-size:0.9rem;opacity:0.8;">Pick any numbered box to reveal your scrambled word</div>
    </div>
    <div class="box-grid" id="scr-boxes"></div>
    <button class="big-btn gray" onclick="backToScrDifficulty()">↩ Change Difficulty</button>
  </div>

  <!-- Question view -->
  <div id="scr-question" class="game-body" style="display:none;">
    <div class="timer-ring-wrap">
      <span class="timer-label">⏱ Timer</span>
      <span class="timer-count" id="scr-timer">10</span>
      <span class="timer-label">seconds</span>
    </div>
    <div class="scramble-board">
      <div class="round-label" id="scr-round-label">ROUND 1</div>
      <div class="scramble-instruction">Unscramble this nutrition word!</div>
      <div class="scramble-word" id="scr-jumbled">RPTNOIE</div>
      <div class="scramble-hint" id="scr-hint"><strong>💡 Hint:</strong> Builds and repairs the body.</div>
      <div class="scramble-input-wrap">
        <input type="text" class="scramble-input" id="scr-input" placeholder="Type your answer..." maxlength="20" autocomplete="off" spellcheck="false" oninput="this.value = this.value.toUpperCase()">
        <button class="big-btn" onclick="checkScramble()">CHECK</button>
      </div>
    </div>
  </div>

  <!-- Answer view -->
  <div id="scr-answer" class="game-body" style="display:none;">
    <div class="answer-card" id="scr-answer-card">
      <div class="result-icon" id="scr-answer-icon">🎉</div>
      <div class="result-title" id="scr-answer-title" style="font-family:'Fredoka One',cursive;font-size:1.8rem;margin-bottom:6px;">ROUND 1 ANSWER</div>
      <div class="result-sub" id="scr-answer-sub">Great job! The correct word is:</div>
      <div class="answer-word" id="scr-answer-word">PROTEIN</div>
      <div class="scramble-hint" id="scr-answer-hint"><strong>💡 Hint:</strong> Builds and repairs the body.</div>
      <button class="big-btn" onclick="afterScrRound()" style="margin-top:14px;" id="scr-continue-btn">↩ Return To Game Board</button>
    </div>
  </div>

  <!-- Final score -->
  <div id="scr-final" class="game-body" style="display:none;">
    <div class="final-score-card">
      <div style="font-size:3rem;">🏆</div>
      <div class="final-player-name" id="scr-final-name">Player Name</div>
      <div style="color:#888;font-weight:700;margin-top:4px;">Final Score</div>
      <div class="final-score-num" id="scr-final-score">0</div>
      <div style="color:#666;font-weight:600;margin-bottom:20px;" id="scr-final-msg">Great effort! You completed 3 tries.</div>
      <button class="big-btn yellow" onclick="goHomeDirect()">🏠 Back to Home</button>
    </div>
  </div>
</div>

<!-- ============ TRUE OR FALSE SCREEN ============ -->
<div id="tof" class="screen">
  <div class="game-header" style="background:var(--blue);">
    <div>
      <div class="game-header-title">✅ True or False</div>
      <div class="game-header-sub">Answer nutrition questions correctly!</div>
    </div>
    <div style="display:flex;align-items:center;gap:10px;">
      <span class="score-badge">Score: <span id="tof-score-disp">0</span> | Try <span id="tof-tries-disp">0</span>/3</span>
      <button class="btn-reset" onclick="confirmReset()">RESET</button>
      <button class="btn-home" onclick="confirmGoHome()">🏠 Home</button>
    </div>
  </div>

  <!-- Instructions -->
  <div id="tof-instructions" class="game-body">
    <div class="instructions-card">
      <div class="instructions-title">📋 How to Play</div>
      <div class="instruction-step"><div class="step-num">1</div><div class="step-text">You will see <strong>20 question boxes</strong> on the game board.</div></div>
      <div class="instruction-step"><div class="step-num">2</div><div class="step-text">Click any box to reveal a nutrition statement.</div></div>
      <div class="instruction-step"><div class="step-num">3</div><div class="step-text">You have <strong>10 seconds</strong> to decide — is it <span style="color:#22c55e;font-weight:800;">TRUE</span> or <span style="color:#ef4444;font-weight:800;">FALSE</span>?</div></div>
      <div class="instruction-step"><div class="step-num">4</div><div class="step-text">Earn <strong>1 point</strong> for each correct answer. You get <strong>3 tries</strong> total!</div></div>
      <div class="instruction-step"><div class="step-num">5</div><div class="step-text">After 3 tries, your final score will be shown. Give it your best shot!</div></div>
      <div style="text-align:center;margin-top:24px;">
        <button class="big-btn" style="background:var(--blue);" onclick="startTOFGame()">▶ START</button>
      </div>
    </div>
  </div>

  <!-- Game board -->
  <div id="tof-board" class="game-body" style="display:none;background:linear-gradient(160deg,#1e40af,#3b82f6);">
    <div style="text-align:center;color:white;animation:slide-down 0.5s ease;">
      <div style="font-family:'Fredoka One',cursive;font-size:1.8rem;margin-bottom:6px;">Game Board</div>
      <div style="font-size:0.9rem;opacity:0.8;">Click any number to open a question</div>
    </div>
    <div class="tof-grid" id="tof-boxes"></div>
    <div class="tries-indicator" id="tof-dots"></div>
  </div>

  <!-- Question view -->
  <div id="tof-question" class="game-body" style="display:none;">
    <div class="timer-ring-wrap">
      <span class="timer-label">⏱ Timer</span>
      <span class="timer-count" id="tof-timer">10</span>
      <span class="timer-label">seconds</span>
    </div>
    <div class="tof-question-card">
      <div class="tof-q-num" id="tof-q-num">Q1 of 20</div>
      <div style="font-size:1rem;font-weight:700;color:#888;margin-bottom:10px;">True or False?</div>
      <div class="tof-q-text" id="tof-q-text">Bananas are a good source of potassium.</div>
      <div class="tof-btns">
        <button class="tof-true-btn" onclick="answerTOF(true)">✅ TRUE</button>
        <button class="tof-false-btn" onclick="answerTOF(false)">❌ FALSE</button>
      </div>
    </div>
  </div>

  <!-- Final score -->
  <div id="tof-final" class="game-body" style="display:none;">
    <div class="final-score-card">
      <div style="font-size:3rem;">🏆</div>
      <div class="final-player-name" id="tof-final-name">Player Name</div>
      <div style="color:#888;font-weight:700;margin-top:4px;">Final Score</div>
      <div class="final-score-num" id="tof-final-score">0</div>
      <div style="color:#666;font-weight:600;margin-bottom:20px;">out of 3 questions answered</div>
      <button class="big-btn yellow" onclick="goHomeDirect()">🏠 Back to Home</button>
    </div>
  </div>
</div>

<!-- ============ MATCHING / MEMORY SCREEN ============ -->
<div id="matching" class="screen">
  <div class="game-header" style="background:#6d28d9;">
    <div>
      <div class="game-header-title">🧠 Memory Match</div>
      <div class="game-header-sub">Match the food to its health benefit!</div>
    </div>
    <div style="display:flex;align-items:center;gap:10px;">
      <span class="score-badge">Matches: <span id="match-score">0</span>/5</span>
      <button class="btn-reset" onclick="confirmReset()">RESET</button>
      <button class="btn-home" onclick="confirmGoHome()">🏠 Home</button>
