}

function openScrBox(idx) {
  scrCurrentBox = idx;
  readySetGo(() => {
    const bank = SCRAMBLE_FINAL[scrDifficulty];
    const wordObj = bank[idx % bank.length];
    const titleMap = { easy: 'EASY', normal: 'NORMAL', hard: 'DIFFICULT' };
    document.getElementById('scr-round-label').textContent = `${titleMap[scrDifficulty]} — ROUND ${idx + 1}`;
    document.getElementById('scr-jumbled').textContent = scramble(wordObj.word);
