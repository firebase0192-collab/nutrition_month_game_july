      <div class="instruction-step"><div class="step-num">2</div><div class="step-text">Players take turns flipping two cards.</div></div>
      <div class="instruction-step"><div class="step-num">3</div><div class="step-text">If the food matches its benefit (e.g., Carrot ↔ Good for eyesight), the player continues matching until all pairs are matched.</div></div>
      <div class="instruction-step"><div class="step-num">4</div><div class="step-text">If not, the cards flip back and the next attempt starts from the top.</div></div>
      <div class="instruction-step"><div class="step-num">5</div><div class="step-text">The player will be given <strong>1 minute</strong> to finish the game.</div></div>
      <div style="text-align:center;margin-top:20px;">
        <button class="big-btn" style="background:#8b5cf6;box-shadow:0 6px 20px rgba(139,92,246,0.4);" onclick="showMatchPreview()">▶ NEXT</button>
      </div>
    </div>
  </div>

  <!-- Preview of pairs: card-by-card reveal -->
  <div id="match-preview" class="game-body" style="display:none;">
    <div class="preview-card">
      <div class="preview-title">📌 Memorize the Pairs!</div>
      <div class="preview-slide-wrap">
        <div class="preview-slide" id="preview-slide">🍎 Apple</div>
      </div>
      <div class="preview-dots" id="preview-dots"></div>
      <div style="text-align:center;margin-top:20px;">
        <button class="big-btn" style="background:#8b5cf6;box-shadow:0 6px 20px rgba(139,92,246,0.4);" id="preview-next-btn" onclick="nextPreviewSlide()">NEXT →</button>
      </div>
    </div>
  </div>

  <!-- Game board -->
  <div id="match-board" class="game-body" style="display:none;">
    <div class="memory-meta">
      <div class="memory-pill"><div class="mp-label">Time Left</div><div class="mp-value" id="memory-timer">1:00</div></div>
      <div class="memory-pill"><div class="mp-label">Matches</div><div class="mp-value" id="memory-matches">0/5</div></div>
    </div>
    <div class="memory-grid" id="memory-grid"></div>
    <div style="text-align:center;font-size:0.85rem;color:#888;font-weight:600;">
      👆 Flip two cards to find a matching pair
    </div>
  </div>

  <!-- Final result -->
  <div id="match-final" class="game-body" style="display:none;">
    <div class="final-score-card">
      <div style="font-size:3rem;" id="match-final-icon">🏆</div>
      <div class="final-player-name" id="match-final-name">Player Name</div>
      <div style="color:#888;font-weight:700;margin-top:4px;" id="match-final-label">Time Used</div>
      <div class="final-score-num" id="match-final-time" style="font-size:3rem;">0:42</div>
      <div style="color:#666;font-weight:600;margin-bottom:20px;" id="match-final-msg">You matched all 5 pairs!</div>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <button class="big-btn yellow" onclick="startMatchingGame()">🔄 Play Again</button>
        <button class="big-btn" style="background:#8b5cf6;" onclick="goHomeDirect()">🏠 Back to Home</button>
      </div>
    </div>
  </div>
</div>

<!-- ============ RESULT OVERLAY (TOF / generic) ============ -->
<div id="result-overlay" class="result-overlay" style="display:none;">
  <div class="result-card" id="result-card">
    <span class="result-icon" id="res-icon">🎉</span>
    <div class="result-title" id="res-title">Correct!</div>
    <div class="result-sub" id="res-sub">Nice one!</div>
    <div class="result-question" id="res-question"></div>
    <div class="result-answer" id="res-answer" style="display:none;">
      <strong id="res-ans-text"></strong>
