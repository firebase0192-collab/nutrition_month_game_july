// Build a flat sequence: [food-only, food+benefit, food-only, food+benefit, ...]
function buildPreviewSequence() {
  const seq = [];
  MATCHING_PAIRS.forEach(pair => {
    seq.push({ type: 'food', pair });
    seq.push({ type: 'pair', pair });
  });
  return seq;
}

function showMatchPreview() {
  document.getElementById('match-instructions').style.display = 'none';
  document.getElementById('match-preview').style.display = 'flex';
  previewSlideIdx = 0;
  window.previewSequence = buildPreviewSequence();
  renderPreviewDots();
  renderPreviewSlide();
}

function renderPreviewDots() {
  const dotsDiv = document.getElementById('preview-dots');
  dotsDiv.innerHTML = '';
  const total = MATCHING_PAIRS.length; // one dot per food pair (covers 2 slides each)
  const currentPairIdx = Math.floor(previewSlideIdx / 2);
  for (let i = 0; i < total; i++) {
    const d = document.createElement('div');
    d.className = 'preview-dot' + (i === currentPairIdx ? ' active' : i < currentPairIdx ? ' done' : '');
    dotsDiv.appendChild(d);
  }
}

function renderPreviewSlide() {
  const slide = document.getElementById('preview-slide');
  const step = window.previewSequence[previewSlideIdx];
  slide.style.animation = 'none';
  void slide.offsetWidth; // restart animation
  slide.style.animation = 'bounce-in 0.5s ease';

  if (step.type === 'food') {
    slide.innerHTML = `${step.pair.food}`;
  } else {
    slide.innerHTML = `${step.pair.food}<span class="pp-arrow">↔</span><span class="pp-benefit">${step.pair.benefit}</span>`;
  }

  renderPreviewDots();

  const isLastSlide = previewSlideIdx === window.previewSequence.length - 1;
  const btn = document.getElementById('preview-next-btn');
  btn.textContent = isLastSlide ? '▶ START MEMORY MATCH' : 'NEXT →';
  btn.onclick = isLastSlide ? startMatchingGame : nextPreviewSlide;
}

function nextPreviewSlide() {
  previewSlideIdx++;
  renderPreviewSlide();
}

function startMatchingGame() {
  document.getElementById('match-instructions').style.display = 'none';
  document.getElementById('match-preview').style.display = 'none';
  document.getElementById('match-final').style.display = 'none';
  document.getElementById('match-board').style.display = 'flex';

  matchedPairs = new Set();
  memoryMatchedCount = 0;
  memoryFlipped = [];
  memoryLock = false;
  memoryTimeLeft = 60;
  document.getElementById('memory-matches').textContent = '0/5';
  document.getElementById('memory-timer').textContent = '1:00';
  document.getElementById('memory-timer').className = 'mp-value';

  buildMemoryCards();
  renderMemoryGrid();
  startMemoryTimer();
}

function buildMemoryCards() {
  let cards = [];
  MATCHING_PAIRS.forEach((pair, i) => {
    cards.push({ id: 'food-' + i, pairId: i, type: 'food', label: pair.food });
    cards.push({ id: 'benefit-' + i, pairId: i, type: 'benefit', label: pair.benefit });
  });
  // shuffle
  for (let i = cards.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [cards[i], cards[j]] = [cards[j], cards[i]];
  }
  memoryCards = cards;
}

function renderMemoryGrid() {
  const grid = document.getElementById('memory-grid');
  grid.innerHTML = '';
  memoryCards.forEach((card, idx) => {
    const el = document.createElement('div');
    el.className = 'memory-card';
    el.dataset.idx = idx;
    el.innerHTML = `
      <div class="mc-face mc-back">❓</div>
      <div class="mc-face mc-front">${card.label}</div>
    `;
    el.onclick = () => flipMemoryCard(idx, el);
    grid.appendChild(el);
  });
}

function flipMemoryCard(idx, el) {
  if (memoryLock) return;
  if (el.classList.contains('flipped') || el.classList.contains('matched')) return;
  if (memoryFlipped.length >= 2) return;

  el.classList.add('flipped');
  memoryFlipped.push({ idx, el });

  if (memoryFlipped.length === 2) {
    memoryLock = true;
    const [first, second] = memoryFlipped;
    const cardA = memoryCards[first.idx];
    const cardB = memoryCards[second.idx];
    const isMatch = cardA.pairId === cardB.pairId && cardA.type !== cardB.type;

    setTimeout(() => {
      if (isMatch) {
        first.el.classList.add('matched');
        second.el.classList.add('matched');
        matchedPairs.add(cardA.pairId);
        memoryMatchedCount++;
        document.getElementById('memory-matches').textContent = `${memoryMatchedCount}/5`;
        launchConfetti(20);
        memoryFlipped = [];
        memoryLock = false;

        if (memoryMatchedCount === 5) {
          finishMemoryGame(true);
        }
      } else {
        first.el.classList.add('wrong-anim');
        second.el.classList.add('wrong-anim');
        setTimeout(() => {
          // flip all unmatched cards back to start (per rule: "cards are flipped back from the start")
          document.querySelectorAll('.memory-card.flipped:not(.matched)').forEach(c => {
            c.classList.remove('flipped', 'wrong-anim');
          });
          memoryFlipped = [];
          memoryLock = false;
        }, 700);
      }
    }, 600);
  }
}

function startMemoryTimer() {
  clearMemoryTimer();
  updateMemoryTimerDisplay();
  memoryTimer = setInterval(() => {
    memoryTimeLeft--;
    updateMemoryTimerDisplay();
    if (memoryTimeLeft <= 0) {
      clearInterval(memoryTimer);
      finishMemoryGame(false);
    }
  }, 1000);
}

function updateMemoryTimerDisplay() {
  const m = Math.floor(memoryTimeLeft / 60);
  const s = memoryTimeLeft % 60;
  const el = document.getElementById('memory-timer');
  el.textContent = `${m}:${s.toString().padStart(2,'0')}`;
  el.className = 'mp-value' + (memoryTimeLeft <= 10 ? ' timer-low' : '');
}

function finishMemoryGame(success) {
  clearMemoryTimer();
  memoryLock = true;
  const timeUsed = 60 - memoryTimeLeft;
  const m = Math.floor(timeUsed / 60);
  const s = timeUsed % 60;

  document.getElementById('match-final-name').textContent = playerName;
  document.getElementById('match-final-icon').textContent = success ? '🏆' : '⏰';
  document.getElementById('match-final-label').textContent = success ? 'Time Used' : 'Time\'s Up!';
  document.getElementById('match-final-time').textContent = success ? `${m}:${s.toString().padStart(2,'0')}` : `${memoryMatchedCount}/5 matched`;
  document.getElementById('match-final-msg').textContent = success
    ? `🎉 Congratulations, ${playerName}! You matched all 5 pairs!`
    : `Time ran out! ${playerName} matched ${memoryMatchedCount} out of 5 pairs.`;

  document.getElementById('match-board').style.display = 'none';
  document.getElementById('match-final').style.display = 'flex';

  if (success) { launchConfetti(80); flashScreen(); }
}

function clearMemoryTimer() { if (memoryTimer) { clearInterval(memoryTimer); memoryTimer = null; } }

// ==========================================
//  UTILITIES
// ==========================================
function clearAllTimers() {
  clearScrTimer();
  clearTOFTimer();
  clearMemoryTimer();
}

document.getElementById('scr-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') checkScramble();
});
document.getElementById('player-name-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') submitPlayerName();
});

// ==========================================
//  INIT
// ==========================================
createParticles();
showScreen('name-entry');
</script>
